{
	email {$ACME_EMAIL}
	admin off

	log {
		output stdout
		format json
		level INFO
	}
}

leetcode.rumjot.me {
	encode gzip zstd

	header {
		X-Content-Type-Options "nosniff"
		X-Frame-Options "DENY"
		Referrer-Policy "strict-origin-when-cross-origin"
		Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
		-Server
	}

	log {
		output stdout
		format json
	}

	reverse_proxy leetcode-backend:3000 {
		transport http {
			dial_timeout            10s
			response_header_timeout 60s
			read_timeout            120s
			write_timeout           120s
		}

		health_uri       /health
		health_interval  30s
		health_timeout   5s
		health_status    2xx
		fail_duration    30s
		max_fails        3
		unhealthy_status 503
	}
}
