# Server
NODE_ENV=production
PORT=8080

# MongoDB Atlas
MONGODB_URI=

# Redis (use redis://redis:6379 inside Docker, redis://localhost:6379 for local dev)
REDIS_URL=redis://redis:6379

# JWT (generate: openssl rand -hex 32)
JWT_ACCESS_SECRET=your-access-token-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-token-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Code Execution Service
EXECUTION_API_URL=https://api.rumjot.me
EXECUTION_API_TOKEN=your-codebox-x-auth-token

# Google OAuth (optional — enables POST /api/auth/google)
GOOGLE_CLIENT_ID=931493966829-ul151o85285kcdphq71kl4rpvfosdmgk.apps.googleusercontent.com

# CORS
CORS_ORIGIN=https://leetcode.rumjot.me

# Cache TTL (seconds)
CACHE_TTL_PROBLEMS=300
CACHE_TTL_PROBLEM_DETAIL=600
CACHE_TTL_USER_PROFILE=300
